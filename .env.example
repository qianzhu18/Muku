# Copy this file to .env before running the app locally.
# The real .env is ignored by git and should never be committed.

# Storage and persisted settings
# macOS / Windows 本地运行时，建议把 DOWNLOAD_DIR 设成绝对路径。
# Docker Compose 会自动把容器内下载根目录固定为 /downloads，
# 并把网页端保存的配置写入 /config/settings.json。
DOWNLOAD_DIR=
# DOWNLOAD_ROOT_DIR=
# VIDEO_DOWNLOADE_CONFIG_DIR=

# Docker Compose host paths
# 默认值使用仓库内的 ./docker-data 目录，Windows 和 macOS 都能直接启动。
# 如果你要映射到宿主机其他目录，再改这两个变量。
DOCKER_DOWNLOADS_DIR=./docker-data/downloads
DOCKER_CONFIG_DIR=./docker-data/config
# Docker/Web 默认占用宿主机 5657，避免和常见本地服务抢 8080。
MUKU_WEB_PORT=5657

# Web UI safety
# By default the app binds to 127.0.0.1 for local use. Set HOST=0.0.0.0 only behind a trusted reverse proxy.
# When MUKU_WEB_TOKEN is set, /api/settings, /api/start and /api/tasks require X-Muku-Web-Token or Bearer auth.
# MUKU_WEB_TOKEN=change-me
MAX_START_URLS=50

# Transcript capture
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
ENABLE_TRANSCRIPTION=true
OPENROUTER_TRANSCRIPTION_MODEL=openai/gpt-audio-mini
OPENROUTER_ARTICLE_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=幕库 Muku
TRANSCRIPTION_LANGUAGE=auto
TRANSCRIPTION_AUDIO_BITRATE=48k
ENABLE_TRANSCRIPTION_CHUNKING=true
TRANSCRIPTION_CHUNK_SECONDS=600
KEEP_TRANSCRIPTION_INPUT=false
YTDLP_REMOTE_COMPONENTS=ejs:github

# Optional global fallback auth
# Used only when no platform-specific auth is configured.
COOKIES_PATH=
# COOKIES_FROM_BROWSER=chrome

# Platform-specific auth is strongly recommended for stable multi-platform usage.
# Web 设置抽屉现在也可以直接保存这些平台 Cookies；如果仓库里已有
# ./cookies/youtube.cookies.txt、./cookies/bilibili.cookies.txt、./cookies/douyin.cookies.txt，
# 应用会自动识别并优先使用这些平台专用文件。
# Recommended preflight for local Python:
# 1. Login in the browser first
# 2. Prefer platform-specific cookies.txt first
# 3. Try *_COOKIES_FROM_BROWSER=chrome for local debugging
# 4. Run `video-downloade doctor --json` and treat browser auth as configured-only until a real URL succeeds
# YOUTUBE_COOKIES_FROM_BROWSER=chrome
# YOUTUBE_COOKIES_PATH=/absolute/path/to/youtube.cookies.txt
# BILIBILI_COOKIES_PATH=/absolute/path/to/bilibili.cookies.txt
# BILIBILI_COOKIES_FROM_BROWSER=chrome
# DOUYIN_COOKIES_PATH=/absolute/path/to/douyin.cookies.txt
# DOUYIN_COOKIES_FROM_BROWSER=chrome

# Optional: dedicated browser profiles
# YOUTUBE_COOKIES_FROM_BROWSER=edge:Profile 1
# BILIBILI_COOKIES_FROM_BROWSER=chrome:Profile 2
# DOUYIN_COOKIES_FROM_BROWSER=chrome:Default

# Docker Compose only:
# 先把宿主机 cookies 文件挂到 ./cookies，再在这里填容器内路径。
# Docker 更稳的默认方案是平台专用 cookies.txt，不建议把 *_COOKIES_FROM_BROWSER 当默认路径。
# DOCKER_COOKIES_PATH=/cookies/cookies.txt
# DOCKER_YOUTUBE_COOKIES_PATH=/cookies/youtube.cookies.txt
# DOCKER_BILIBILI_COOKIES_PATH=/cookies/bilibili.cookies.txt
# DOCKER_DOUYIN_COOKIES_PATH=/cookies/douyin.cookies.txt

# Transcript cleanup
ENABLE_AI_CLEANUP=true
AI_CLEANUP_BASE_URL=https://openrouter.ai/api/v1
AI_CLEANUP_API_KEY=
AI_CLEANUP_MODEL=stepfun/step-3.7-flash
AI_CLEANUP_PROVIDER_LABEL=openrouter
# Optional: override fallback ladder, comma-separated.
# AI_CLEANUP_FALLBACK_MODELS=
AI_CLEANUP_FALLBACK_LOCAL=true
AI_CLEANUP_TIMEOUT_SECONDS=120
AI_CLEANUP_MAX_RETRIES=2
# AI_CLEANUP_PROMPT_TEXT=

# Article draft
ENABLE_ARTICLE_DRAFT=true
ARTICLE_DRAFT_BASE_URL=https://openrouter.ai/api/v1
ARTICLE_DRAFT_API_KEY=
ARTICLE_DRAFT_MODEL=stepfun/step-3.7-flash
ARTICLE_DRAFT_PROVIDER_LABEL=openrouter
# ARTICLE_DRAFT_FALLBACK_MODELS=
ARTICLE_DRAFT_TIMEOUT_SECONDS=180
ARTICLE_DRAFT_MAX_RETRIES=2
# ARTICLE_DRAFT_PROMPT_TEXT=

# Optional: use a separate backend for knowledge-base notes.
# Leave these commented if you want knowledge generation to reuse ARTICLE_DRAFT_*.
# ENABLE_KNOWLEDGE_DRAFT=true
# KNOWLEDGE_DRAFT_BASE_URL=https://openrouter.ai/api/v1
# KNOWLEDGE_DRAFT_API_KEY=
# KNOWLEDGE_DRAFT_MODEL=stepfun/step-3.7-flash
# KNOWLEDGE_DRAFT_PROVIDER_LABEL=openrouter
# KNOWLEDGE_DRAFT_FALLBACK_MODELS=
# KNOWLEDGE_DRAFT_TIMEOUT_SECONDS=180
# KNOWLEDGE_DRAFT_MAX_RETRIES=2
# KNOWLEDGE_DRAFT_PROMPT_TEXT=
