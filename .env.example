# Copy this file to .env before running the app locally.
# The real .env is ignored by git and should never be committed.

# Transcript capture
OPENROUTER_API_KEY=
ENABLE_TRANSCRIPTION=true
OPENROUTER_TRANSCRIPTION_MODEL=openai/gpt-audio-mini
TRANSCRIPTION_LANGUAGE=auto
TRANSCRIPTION_AUDIO_BITRATE=48k

# Optional subtitle auth
# Pick one and leave the other blank:
COOKIES_PATH=
# COOKIES_FROM_BROWSER=chrome

# Docker Compose only:
# DOCKER_COOKIES_PATH=/cookies.txt

# Transcript cleanup
ENABLE_AI_CLEANUP=true
AI_CLEANUP_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
AI_CLEANUP_API_KEY=
AI_CLEANUP_MODEL=GLM-4.5
AI_CLEANUP_PROVIDER_LABEL=zhipu-coding
AI_CLEANUP_FALLBACK_LOCAL=true

# Article draft
ENABLE_ARTICLE_DRAFT=true
ARTICLE_DRAFT_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
ARTICLE_DRAFT_API_KEY=
ARTICLE_DRAFT_MODEL=GLM-4.5
ARTICLE_DRAFT_PROVIDER_LABEL=zhipu-coding
